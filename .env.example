# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Emulator (for development)
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=localhost
VITE_FIREBASE_EMULATOR_PORT=9099

# Existing environment variables
VITE_API_URL=http://localhost:3000/api
VITE_AMADEUS_CLIENT_ID=your_amadeus_client_id
VITE_AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

is # ---- Server-side Supabase (used by the backend / API) ----
# The backend reads SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (service role bypasses RLS).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional anon-key fallback if the service role key is not provided
SUPABASE_ANON_KEY=your_anon_key_here

# ---- Auth (agent JWTs) ----
# REQUIRED: there is no default — a missing/weak secret lets anyone forge tokens.
JWT_SECRET=generate_a_long_random_secret_here
JWT_EXPIRE=30d

# ARC Pay Gateway Configuration
# Obtain test credentials from: https://www2.arccorp.com/support/arc-pay/
# API Documentation: https://api.arcpay.travel/api/documentation/integrationGuidelines/index.html
# REQUIRED:
ARC_PAY_MERCHANT_ID=your_merchant_id_here
ARC_PAY_API_PASSWORD=your_api_password_here
ARC_PAY_BASE_URL=https://api.arcpay.travel/api/rest/version/77
# OPTIONAL — derived from ARC_PAY_BASE_URL/ARC_PAY_MERCHANT_ID when omitted:
#   ARC_PAY_API_URL           (default: <BASE_URL>/merchant/<MERCHANT_ID>)
#   ARC_PAY_CHECK_GATEWAY_URL (default: <BASE_URL>/information)
#   ARC_PAY_API_USERNAME      (default: <MERCHANT_ID>)
# ARC_PAY_PORTAL_URL=https://api.arcpay.travel/ma/
# Feature flags (default false):
# ARC_PAY_REAL_TIME=true
# ARC_PAY_PRODUCTION_READY_MODE=true
# Additional gateway passwords (optional):
# ARC_PAY_INTEGRATION_PASSWORD_1=...
# ARC_PAY_INTEGRATION_PASSWORD_2=...
# ARC_PAY_REPORTING_PASSWORD_1=...
# ARC_PAY_REPORTING_PASSWORD_2=...

# For testing, use test credentials from ARC
# Production credentials require approval from ARC
# Authentication: Basic HTTP Auth with merchant.<merchantId>:apiPassword

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
ADMIN_EMAIL=admin@yourcompany.com
FRONTEND_URL=http://localhost:3000

# Redis caching (optional but recommended for production stability/perf)
# When unset, caching is disabled and all calls pass through to the DB/APIs.
REDIS_URL=redis://localhost:6379
# Rate limiting (requests per minute per IP) — optional overrides
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=30
# CORS allowlist — comma-separated origins (avoid "*" in production)
CORS_ORIGIN=http://localhost:5173,https://www.jetsetterss.com

# Error monitoring (Sentry) — optional; leave unset to disable
SENTRY_DSN=
VITE_SENTRY_DSN=
# Sampling 0..1 (0 = errors only, no performance traces)
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Global outbound HTTP timeout in ms (axios safety net)
HTTP_TIMEOUT_MS=30000

# Local testing: when true, /api/flights/search returns mock flights and skips Amadeus
# (useful when the Amadeus key is rate-limited). NEVER enable in production.
ENABLE_MOCK_FLIGHTS=false
